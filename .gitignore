# SignaCheck .gitignore

# =============================================================================
# CREDENTIALS
# =============================================================================
credentials/
secrets/
*-key.json
*-credentials.json
service-account*.json

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/

# =============================================================================
# Jupyter Notebooks
# =============================================================================
.ipynb_checkpoints/
*.ipynb_checkpoints
*.ipynb

# =============================================================================
# IDE / Editor
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# =============================================================================
# Data files 
# =============================================================================
data/*
*.csv
*.xlsx
*.parquet
outputs/
*.keras
*.gpkg

# =============================================================================
# Environment variables
# =============================================================================
.env
.env.local
*.env
.venv/

# =============================================================================
# OS generated files
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
